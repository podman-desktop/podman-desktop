{
  "name": "@podman-desktop/cli-installer",
  "version": "1.29.0-next",
  "description": "Shared CLI installer helpers for Podman Desktop extensions",
  "type": "module",
  "license": "Apache-2.0",
  "files": [
    "dist",
    "!dist/**/*.spec.*"
